# Variables d'environnement backend
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-medium-latest












# version: '3.8'
services:
  backend:
    build: ./backend
    ports:
      - "4000:4000"
    environment:
      - NODE_ENV=development
      - DB_PATH=/app/data/database.sqlite
      - GITHUB_OWNER=sletonqu
      - GITHUB_REPO=ActivitesClasse
      - GITHUB_BRANCH=main
      - ENABLE_ADMIN_UPDATE_TRIGGER=true
      # Optional for AI sentence generation from the admin panel:
      - OPENAI_API_KEY=
      - OPENAI_MODEL=gpt-4.1-mini
      - GEMINI_API_KEY=AIzaSyB2NNnNkxA-c-ZrXNO6I2hTj28-2893Xz8
      - GEMINI_MODEL=gemini-2.5-flash-lite
      - MISTRAL_API_KEY=MRolKFWJHLt0esN4QROSxgwmE6nwZ7pl
      - MISTRAL_MODEL=mistral-medium-latest
      - AI_LOCAL_TOKEN_CORRECTION=false
      # Optional for host-side automation from the admin panel:
      # - HOST_UPDATER_URL=http://host.docker.internal:8765/update
      # - UPDATER_TOKEN=your_secure_token
    volumes:
      - db-data:/app/data
  frontend:
    build: ./frontend
    ports:
      - "3000:3000"
    environment:
      - NODE_ENV=development
    depends_on:
      - backend

volumes:
  db-data: